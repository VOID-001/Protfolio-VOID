      "required": true,
      "default": "AI_ML"
    },
    "proficiency": { "type": "integer", "min": 1, "max": 10, "default": 5 },
    "tools": { "type": "json", "default": [] },
    "relatedProjectSlugs": { "type": "json", "default": [] }
  }
}

