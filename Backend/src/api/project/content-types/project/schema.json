{
  "kind": "collectionType",
  "collectionName": "projects",
  "info": {
    "singularName": "project",
    "pluralName": "projects",
    "displayName": "Project",
    "description": "Portfolio projects displayed as planets in orbit"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": { "type": "string", "required": true },
    "slug": { "type": "uid", "targetField": "title", "required": true },
    "shortDescription": { "type": "string", "maxLength": 280 },
    "fullCaseStudy": { "type": "richtext" },
    "stack": { "type": "json", "default": [] },
    "domain": {
      "type": "enumeration",
      "enum": ["AI_ML", "LLM_INFRA", "BACKEND", "FRONTEND", "DEVOPS", "RESEARCH"],
      "required": true,
      "default": "AI_ML"
    },
    "orbitTier": {
      "type": "enumeration",
      "enum": ["A", "B", "C"],
      "required": true,
      "default": "B"
    },
    "complexity": { "type": "integer", "min": 1, "max": 10, "default": 5 },
    "recency": { "type": "integer", "min": 1, "max": 10, "default": 5 },
    "thumbnailUrl": { "type": "string", "default": "/placeholder.png" },
    "videoLoopUrl": { "type": "string" },
    "githubUrl": { "type": "string" },
    "projectUrl": { "type": "string" },
    "projectStatus": {
      "type": "enumeration",
      "enum": ["LIVE", "WIP", "ARCHIVED"],
      "required": true,
      "default": "WIP"
    },
    "planetColor": {
      "type": "enumeration",
      "enum": ["purple", "blue", "green", "red", "orange", "yellow", "cyan", "magenta", "white", "silver", "gold", "rose", "teal", "indigo", "violet", "crimson", "emerald", "sapphire", "amethyst", "obsidian"],
      "required": true,
      "default": "purple"
    },
    "graphEdges": { "type": "json", "default": [] }
  }
}

