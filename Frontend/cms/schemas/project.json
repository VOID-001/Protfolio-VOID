{
  "kind": "collectionType",
  "collectionName": "projects",
  "info": {
    "singularName": "project",
    "pluralName": "projects",
    "displayName": "Project",
    "description": "Portfolio Projects mapped to Orbs"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "shortDescription": {
      "type": "string",
      "maxLength": 200
    },
    "fullCaseStudy": {
      "type": "richtext"
    },
    "stack": {
      "type": "json"
    },
    "domain": {
      "type": "enumeration",
      "enum": [
        "AI_ML",
        "LLM_INFRA",
        "BACKEND",
        "FRONTEND",
        "DEVOPS",
        "RESEARCH"
      ]
    },
    "orbitTier": {
      "type": "enumeration",
      "enum": [
        "A",
        "B",
        "C"
      ]
    },
    "complexity": {
      "type": "integer",
      "min": 1,
      "max": 10
    },
    "recency": {
      "type": "integer",
      "min": 1,
      "max": 10
    },
    "thumbnailUrl": {
      "type": "string"
    },
    "videoLoopUrl": {
      "type": "string"
    },
    "githubUrl": {
      "type": "string"
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "LIVE",
        "WIP",
        "ARCHIVED"
      ]
    },
    "graphEdges": {
      "type": "json"
    }
  }
}
